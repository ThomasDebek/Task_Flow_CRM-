<span>
  <% if page.current? %>
    <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-slate-900 text-white font-semibold">
      <%= page %>
    </span>
  <% else %>
    <%= link_to page,
                url,
                remote: remote,
                rel: page.rel,
                class: "inline-flex h-10 w-10 items-center justify-center rounded-lg border border-slate-300 bg-white text-slate-700 hover:bg-slate-100 transition" %>
  <% end %>
</span>