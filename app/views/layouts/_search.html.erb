<div class="w-96">
  <%= form_with url: clients_path,
                method: :get,
                local: true do |form| %>

    <%= form.text_field :query,
                        value: params[:query],
                        placeholder: "Search clients...",
                        class: "w-full rounded-lg border border-slate-300 px-4 py-2 text-sm focus:border-slate-500 focus:ring-slate-500" %>

  <% end %>
</div>