<div class="mt-10 border-t border-slate-200 pt-8">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between mb-6">
    <div>
      <h2 class="text-2xl font-bold text-slate-900">Tasks</h2>
      <p class="mt-1 text-slate-600">Manage follow-ups, deadlines and client work.</p>
    </div>

    <%= link_to "New task", new_client_task_path(@client),
                class: "inline-flex items-center justify-center rounded-lg bg-slate-900 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
  </div>

  <div class="mb-6 flex flex-wrap gap-2">
    <%= link_to "All", client_path(@client),
                class: "rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" %>

    <%= link_to "Pending", client_path(@client, task_filter: "pending"),
                class: "rounded-full border border-yellow-300 bg-yellow-50 px-4 py-2 text-sm font-medium text-yellow-800 hover:bg-yellow-100" %>

    <%= link_to "In progress", client_path(@client, task_filter: "in_progress"),
                class: "rounded-full border border-blue-300 bg-blue-50 px-4 py-2 text-sm font-medium text-blue-800 hover:bg-blue-100" %>

    <%= link_to "Done", client_path(@client, task_filter: "done"),
                class: "rounded-full border border-green-300 bg-green-50 px-4 py-2 text-sm font-medium text-green-800 hover:bg-green-100" %>

    <%= link_to "Overdue", client_path(@client, task_filter: "overdue"),
                class: "rounded-full border border-red-300 bg-red-50 px-4 py-2 text-sm font-medium text-red-800 hover:bg-red-100" %>
  </div>

  <% if @tasks.any? %>
    <div class="space-y-4">
      <% @tasks.each do |task| %>
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm hover:shadow-md transition">
          <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <h3 class="text-lg font-semibold text-slate-900">
                <%= task.title %>
              </h3>

              <p class="mt-2 text-sm leading-6 text-slate-600">
                <%= task.description.presence || "No description provided." %>
              </p>
            </div>

            <span class="inline-flex w-fit items-center rounded-full px-3 py-1 text-xs font-semibold
              <%= case task.status
                  when "pending"
                    "bg-yellow-100 text-yellow-800"
                  when "in_progress"
                    "bg-blue-100 text-blue-800"
                  when "done"
                    "bg-green-100 text-green-800"
                  else
                    "bg-slate-100 text-slate-700"
                  end %>">
              <%= task.status.humanize %>
            </span>
          </div>

          <div class="mt-5 flex flex-col gap-3 border-t border-slate-100 pt-4 sm:flex-row sm:items-center sm:justify-between">
            <div class="text-sm text-slate-600">
              <span class="font-medium text-slate-900">Due date:</span>
              <%= task.due_date.present? ? task.due_date.strftime("%d.%m.%Y") : "Not set" %>
            </div>

            <div class="flex items-center gap-4">
              <%= link_to "Edit", edit_client_task_path(@client, task),
                          class: "text-sm font-semibold text-indigo-600 hover:text-indigo-800" %>

              <%= link_to "Delete", client_task_path(@client, task),
                          data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                          class: "text-sm font-semibold text-red-600 hover:text-red-800" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-2xl border border-dashed border-slate-300 bg-white p-10 text-center">
      <h3 class="text-xl font-semibold text-slate-900">No tasks found</h3>
      <p class="mt-2 text-slate-600">
        Add a task or change the selected filter.
      </p>

      <div class="mt-6">
        <%= link_to "Create task", new_client_task_path(@client),
                    class: "inline-flex items-center rounded-lg bg-slate-900 px-5 py-3 text-sm font-semibold text-white hover:bg-slate-800" %>
      </div>
    </div>
  <% end %>
</div>