<div class="max-w-4xl mx-auto">
  <div class="flex items-center justify-between gap-4 mb-8">
    <div>
      <h1 class="text-3xl font-bold text-slate-900"><%= @client.name %></h1>
      <p class="mt-2 text-slate-600"><%= @client.company_name %></p>
    </div>

    <div class="flex items-center gap-3">
      <%= link_to "Edit", edit_client_path(@client), class: "inline-flex items-center rounded-lg border border-slate-300 bg-white px-5 py-3 text-slate-700 font-medium hover:bg-slate-50" %>
      <%= link_to "Delete", client_path(@client),
                  data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                  class: "inline-flex items-center rounded-lg bg-red-600 px-5 py-3 text-white font-medium hover:bg-red-700" %>
    </div>
  </div>

  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-8 space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <p class="text-sm font-medium text-slate-500">Full name</p>
        <p class="mt-1 text-lg text-slate-900"><%= @client.name %></p>
      </div>

      <div>
        <p class="text-sm font-medium text-slate-500">Status</p>
        <span class="<%= status_badge(@client.status) %>">
          <%= @client.status.capitalize %>
        </span>
      </div>

      <div>
        <p class="text-sm font-medium text-slate-500">Email</p>
        <p class="mt-1 text-lg text-slate-900"><%= @client.email %></p>
      </div>

      <div>
        <p class="text-sm font-medium text-slate-500">Phone</p>
        <p class="mt-1 text-lg text-slate-900"><%= @client.phone.presence || "Not provided" %></p>
      </div>

      <div>
        <p class="text-sm font-medium text-slate-500">Company</p>
        <p class="mt-1 text-lg text-slate-900"><%= @client.company_name %></p>
      </div>

      <div>
        <p class="text-sm font-medium text-slate-500">Created at</p>
        <p class="mt-1 text-lg text-slate-900"><%= @client.created_at.strftime("%d.%m.%Y %H:%M") %></p>
      </div>
    </div>

    <div class="pt-4 border-t border-slate-200">
      <%= link_to "Back to clients", clients_path, class: "text-sm font-medium text-slate-700 hover:text-slate-900" %>
    </div>
  </div>
</div>