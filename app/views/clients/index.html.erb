<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="text-3xl font-bold text-slate-900">Clients</h1>
    <p class="mt-2 text-slate-600">Manage your clients in one place.</p>
  </div>

  <%= link_to "New client", new_client_path, class: "inline-flex items-center rounded-lg bg-slate-900 px-5 py-3 text-white font-medium hover:bg-slate-800" %>
</div>

<% if @clients.any? %>
  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
    <% @clients.each do |client| %>
      <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h2 class="text-xl font-semibold text-slate-900">
              <%= link_to client.name, client_path(client), class: "hover:underline" %>
            </h2>
            <p class="mt-1 text-sm text-slate-500"><%= client.company_name %></p>
          </div>

          <span class="<%= status_badge(client.status) %>">
            <%= client.status.capitalize %>
          </span>
        </div>

        <div class="mt-5 space-y-2 text-sm text-slate-600">
          <p><strong>Email:</strong> <%= client.email %></p>
          <p><strong>Phone:</strong> <%= client.phone.presence || "Not provided" %></p>
        </div>

        <div class="mt-6 flex items-center gap-3">
          <%= link_to "Show", client_path(client), class: "text-sm font-medium text-slate-700 hover:text-slate-900" %>
          <%= link_to "Edit", edit_client_path(client), class: "text-sm font-medium text-indigo-600 hover:text-indigo-800" %>
          <%= link_to "Delete", client_path(client),
                      data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                      class: "text-sm font-medium text-red-600 hover:text-red-800" %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-10 text-center">
    <h2 class="text-xl font-semibold text-slate-900">No clients yet</h2>
    <p class="mt-3 text-slate-600">Create your first client to get started.</p>
    <div class="mt-6">
      <%= link_to "Create client", new_client_path, class: "inline-flex items-center rounded-lg bg-slate-900 px-5 py-3 text-white font-medium hover:bg-slate-800" %>
    </div>
  </div>
<% end %>


<div class="mt-8">
  <%= paginate @clients %>
</div>