<div class="max-w-md mx-auto">
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-8">

    <div class="mb-8 text-center">
      <h1 class="text-3xl font-bold text-slate-900">
        Create Account
      </h1>

      <p class="mt-2 text-slate-600">
        Start managing your clients, leads and tasks.
      </p>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>

      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="mb-5">
        <%= f.label :email, class: "block text-sm font-medium text-slate-700 mb-2" %>

        <%= f.email_field :email,
                          autofocus: true,
                          autocomplete: "email",
                          class: "w-full rounded-lg border border-slate-300 px-4 py-3 text-slate-700 focus:border-slate-500 focus:ring-slate-500" %>
      </div>

      <div class="mb-5">
        <%= f.label :password, class: "block text-sm font-medium text-slate-700 mb-2" %>

        <% if @minimum_password_length %>
          <p class="mb-2 text-sm text-slate-500">
            Minimum <%= @minimum_password_length %> characters
          </p>
        <% end %>

        <%= f.password_field :password,
                             autocomplete: "new-password",
                             class: "w-full rounded-lg border border-slate-300 px-4 py-3 text-slate-700 focus:border-slate-500 focus:ring-slate-500" %>
      </div>

      <div class="mb-6">
        <%= f.label :password_confirmation, class: "block text-sm font-medium text-slate-700 mb-2" %>

        <%= f.password_field :password_confirmation,
                             autocomplete: "new-password",
                             class: "w-full rounded-lg border border-slate-300 px-4 py-3 text-slate-700 focus:border-slate-500 focus:ring-slate-500" %>
      </div>

      <div>
        <%= f.submit "Create Account",
                     class: "w-full rounded-lg bg-slate-900 px-5 py-3 text-white font-medium hover:bg-slate-800 cursor-pointer" %>
      </div>

    <% end %>

    <div class="mt-6 border-t border-slate-200 pt-6 text-center">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>