<div class="max-w-md mx-auto">
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-8">

    <div class="mb-8 text-center">
      <h1 class="text-3xl font-bold text-slate-900">
        Account Settings
      </h1>

      <p class="mt-2 text-slate-600">
        Update your account information.
      </p>
    </div>

    <%= form_for(resource, as: resource_name,
                 url: registration_path(resource_name),
                 html: { method: :put }) do |f| %>

      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="mb-5">
        <%= f.label :email, class: "block text-sm font-medium text-slate-700 mb-2" %>

        <%= f.email_field :email,
                          autofocus: true,
                          autocomplete: "email",
                          class: "w-full rounded-lg border border-slate-300 px-4 py-3" %>
      </div>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <div class="mb-5 rounded-lg bg-yellow-50 border border-yellow-200 p-4 text-sm text-yellow-800">
          Waiting confirmation for:
          <strong><%= resource.unconfirmed_email %></strong>
        </div>
      <% end %>

      <div class="mb-5">
        <%= f.label :password, class: "block text-sm font-medium text-slate-700 mb-2" %>

        <p class="mb-2 text-sm text-slate-500">
          Leave blank if you don't want to change it.
        </p>

        <%= f.password_field :password,
                             autocomplete: "new-password",
                             class: "w-full rounded-lg border border-slate-300 px-4 py-3" %>

        <% if @minimum_password_length %>
          <p class="mt-2 text-sm text-slate-500">
            Minimum <%= @minimum_password_length %> characters
          </p>
        <% end %>
      </div>

      <div class="mb-5">
        <%= f.label :password_confirmation, class: "block text-sm font-medium text-slate-700 mb-2" %>

        <%= f.password_field :password_confirmation,
                             autocomplete: "new-password",
                             class: "w-full rounded-lg border border-slate-300 px-4 py-3" %>
      </div>

      <div class="mb-6">
        <%= f.label :current_password, class: "block text-sm font-medium text-slate-700 mb-2" %>

        <p class="mb-2 text-sm text-slate-500">
          Required to confirm changes.
        </p>

        <%= f.password_field :current_password,
                             autocomplete: "current-password",
                             class: "w-full rounded-lg border border-slate-300 px-4 py-3" %>
      </div>

      <%= f.submit "Update Account",
                   class: "w-full rounded-lg bg-slate-900 px-5 py-3 text-white font-medium hover:bg-slate-800 cursor-pointer" %>

    <% end %>

  </div>

  <div class="mt-6 bg-white rounded-2xl border border-red-200 shadow-sm p-6">
    <h2 class="text-lg font-semibold text-red-700">
      Danger Zone
    </h2>

    <p class="mt-2 text-sm text-slate-600">
      Permanently delete your account and all associated data.
    </p>

    <div class="mt-4">
      <%= button_to "Delete Account",
                    registration_path(resource_name),
                    method: :delete,
                    data: {
                      turbo_confirm: "Are you sure?"
                    },
                    class: "rounded-lg bg-red-600 px-5 py-3 text-white font-medium hover:bg-red-700" %>
    </div>
  </div>
</div>