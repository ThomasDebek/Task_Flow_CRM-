<div class="max-w-md mx-auto">
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-8">

    <div class="mb-8 text-center">
      <h1 class="text-3xl font-bold text-slate-900">
        Welcome Back
      </h1>

      <p class="mt-2 text-slate-600">
        Sign in to your TaskFlow CRM account.
      </p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

      <div class="mb-5">
        <%= f.label :email, class: "block text-sm font-medium text-slate-700 mb-2" %>

        <%= f.email_field :email,
                          autofocus: true,
                          autocomplete: "email",
                          class: "w-full rounded-lg border border-slate-300 px-4 py-3 text-slate-700 focus:border-slate-500 focus:ring-slate-500" %>
      </div>

      <div class="mb-5">
        <%= f.label :password, class: "block text-sm font-medium text-slate-700 mb-2" %>

        <%= f.password_field :password,
                             autocomplete: "current-password",
                             class: "w-full rounded-lg border border-slate-300 px-4 py-3 text-slate-700 focus:border-slate-500 focus:ring-slate-500" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="mb-6 flex items-center gap-2">
          <%= f.check_box :remember_me,
                          class: "rounded border-slate-300 text-slate-900 focus:ring-slate-500" %>

          <%= f.label :remember_me,
                      class: "text-sm text-slate-600" %>
        </div>
      <% end %>

      <div>
        <%= f.submit "Log in",
                     class: "w-full rounded-lg bg-slate-900 px-5 py-3 text-white font-medium hover:bg-slate-800 cursor-pointer" %>
      </div>

    <% end %>

    <div class="mt-6 border-t border-slate-200 pt-6 text-center">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>