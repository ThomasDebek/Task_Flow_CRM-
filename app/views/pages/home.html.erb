<div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
  <div>
    <p class="text-sm font-semibold uppercase tracking-widest text-indigo-600 mb-3">
      Simple CRM for growing teams
    </p>

    <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 leading-tight">
      Manage clients, leads and tasks in one clean dashboard
    </h1>

    <p class="mt-6 text-lg text-slate-600 leading-8">
      TaskFlow CRM helps you keep customer data organized, follow your sales pipeline,
      and stay on top of important tasks without getting lost in spreadsheets.
    </p>

    <div class="mt-8 flex flex-wrap gap-4">
      <%= link_to "View clients", clients_path, class: "inline-flex items-center rounded-lg bg-slate-900 px-5 py-3 text-white font-medium hover:bg-slate-800" %>
      <%= link_to "View leads", leads_path, class: "inline-flex items-center rounded-lg border border-slate-300 bg-white px-5 py-3 text-slate-700 font-medium hover:bg-slate-50" %>
    </div>
  </div>

  <div class="bg-white rounded-2xl shadow-lg border border-slate-200 p-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

      <%= link_to clients_path, class: "block rounded-xl bg-slate-50 p-5 border border-slate-200 hover:shadow-md transition" do %>
        <p class="text-sm text-slate-500">Clients</p>
        <p class="mt-2 text-3xl font-bold text-slate-900">
          <%= @clients_count %>
        </p>
      <% end %>

      <%= link_to leads_path, class: "block rounded-xl bg-slate-50 p-5 border border-slate-200 hover:shadow-md transition" do %>
        <p class="text-sm text-slate-500">Leads</p>
        <p class="mt-2 text-3xl font-bold text-slate-900">
          <%= @leads_count %>
        </p>
      <% end %>

      <%= link_to clients_path, class: "block rounded-xl bg-slate-50 p-5 border border-slate-200 hover:shadow-md transition" do %>
        <p class="text-sm text-slate-500">Pending Tasks</p>
        <p class="mt-2 text-3xl font-bold text-yellow-700">
          <%= @tasks_pending %>
        </p>
      <% end %>

      <%= link_to clients_path, class: "block rounded-xl bg-slate-50 p-5 border border-slate-200 hover:shadow-md transition" do %>
        <p class="text-sm text-slate-500">Overdue Tasks</p>
        <p class="mt-2 text-3xl font-bold text-red-700">
          <%= @tasks_overdue %>
        </p>
      <% end %>

    </div>
  </div>
</div>

<section id="features" class="mt-20">
  <div class="mb-8">
    <h2 class="text-3xl font-bold text-slate-900">Why this app is worth building</h2>
    <p class="mt-3 text-slate-600 text-lg">
      It is a practical Ruby on Rails portfolio project with real business logic.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
      <h3 class="text-xl font-semibold text-slate-900">Client management</h3>
      <p class="mt-3 text-slate-600">
        Store contact details, company names, and customer status in one place.
      </p>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
      <h3 class="text-xl font-semibold text-slate-900">Lead tracking</h3>
      <p class="mt-3 text-slate-600">
        Track potential customers from first contact to conversion.
      </p>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
      <h3 class="text-xl font-semibold text-slate-900">Task planning</h3>
      <p class="mt-3 text-slate-600">
        Organize follow-ups, deadlines, and notes connected to real clients.
      </p>
    </div>
  </div>
</section>

<div class="mt-20 grid grid-cols-1 lg:grid-cols-2 gap-10">

  <!-- Recent Leads -->
  <div>
    <h2 class="text-2xl font-bold text-slate-900 mb-4">Recent Leads</h2>

    <div class="space-y-3">
      <% @recent_leads.each do |lead| %>
        <%= link_to lead_path(lead), class: "block bg-white border rounded-xl p-4 hover:shadow transition" do %>
          <p class="font-semibold text-slate-900">
            <%= lead.first_name %> <%= lead.last_name %>
          </p>
          <p class="text-sm text-slate-600">
            <%= lead.company_name %>
          </p>
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Recent Tasks -->
  <div>
    <h2 class="text-2xl font-bold text-slate-900 mb-4">Recent Tasks</h2>

    <div class="space-y-3">
      <% @recent_tasks.each do |task| %>
        <%= link_to client_path(task.client), class: "block bg-white border rounded-xl p-4 hover:shadow transition" do %>
        <p class="font-semibold text-slate-900">
            <%= task.title %>
          </p>
          <p class="text-sm text-slate-600">
            <%= task.client.name %>
          </p>
        <% end %>
      <% end %>
    </div>
  </div>

</div>