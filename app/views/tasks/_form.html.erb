<%= form_with model: [@client, @task], class: "space-y-6" do |form| %>
  <% if @task.errors.any? %>
    <div class="rounded-lg border border-red-200 bg-red-50 p-4">
      <h2 class="text-lg font-semibold text-red-800 mb-2">
        Please fix the following errors:
      </h2>
      <ul class="list-disc list-inside text-red-700 space-y-1">
        <% @task.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, class: "block text-sm font-medium text-slate-700 mb-2" %>
    <%= form.text_field :title, class: "w-full rounded-lg border border-slate-300 px-4 py-2" %>
  </div>

  <div>
    <%= form.label :description, class: "block text-sm font-medium text-slate-700 mb-2" %>
    <%= form.text_area :description, rows: 4, class: "w-full rounded-lg border border-slate-300 px-4 py-2" %>
  </div>

  <div>
    <%= form.label :status, class: "block text-sm font-medium text-slate-700 mb-2" %>
    <%= form.select :status,
                    [["Pending", "pending"], ["In Progress", "in_progress"], ["Done", "done"]],
                    {},
                    class: "w-full rounded-lg border border-slate-300 px-4 py-2" %>
  </div>

  <div>
    <%= form.label :due_date, class: "block text-sm font-medium text-slate-700 mb-2" %>
    <%= form.date_field :due_date, class: "w-full rounded-lg border border-slate-300 px-4 py-2" %>
  </div>

  <div class="flex items-center gap-3">
    <%= form.submit class: "inline-flex items-center rounded-lg bg-slate-900 px-5 py-3 text-white font-medium hover:bg-slate-800 cursor-pointer" %>
    <%= link_to "Back", client_path(@client), class: "inline-flex items-center rounded-lg border border-slate-300 bg-white px-5 py-3 text-slate-700 font-medium hover:bg-slate-50" %>
  </div>
<% end %>